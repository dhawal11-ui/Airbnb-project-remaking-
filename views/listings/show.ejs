<% layout("/layouts/boilerplate")%>
<body>
  <div class="row mt-3">
    <div class="col-8 offset-3">
      <h3>Listing Details</h3>
    </div>

    <div class="card col-6 offset-3 show-card">
      <img src="<%=listing.image%>" class="card-img-top show-img" alt="listing_iamge" />
      <div class="card-body">
        <b><%=listing.title %></b>
        <br />

        <%=listing.description%>
        <!-- ruppees me quomma wagera lagakar dega yeh function 
       its not local its locale-->
        <br />
        &#8377; <%= (listing.price != null) ? listing.price.toLocaleString("en-In") : 'N/A' %>
        <br />
        <%=listing.location%>
        <br />
        <%=listing.country%>
      </div>
    </div>

    <br />

    <div class="btns mb-3">
      <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark col-1 offset-3 color-btn">Edit </a>

      <!-- yehj bas show page hai isliye form sirf req bhehjne ke liye rakhe for delete.. Edit ke liye anchor tag req bhejega to edit.ejs per -->
      <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-dark offset-5">Delete</button>
      </form>
    </div>
  </div>
</body>
