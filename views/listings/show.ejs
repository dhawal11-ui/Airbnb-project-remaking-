<% layout("layouts/boilerplate") %>
<body>
  <div class="row mt-3">
    <div class="col-8 offset-3">
      <h3><%=listing.title %></h3>
    </div>

    <div class="card col-6 offset-3 show-card">
      <img
        src="<%=listing.image%>"
        class="card-img-top show-img"
        alt="listing_iamge"
      />
      <div class="card-body">
        <br />

        <%=listing.description%>
        <!-- ruppees me quomma wagera lagakar dega yeh function 
       its not local its locale-->
        <br />
        &#8377; <%= (listing.price != null) ?
        listing.price.toLocaleString("en-In") : 'N/A' %>
        <br />
        <%=listing.location%>
        <br />
        <%=listing.country%>
      </div>
    </div>

    <br />

    <div class="btns mb-3">
      <a
        href="/listings/<%=listing._id%>/edit"
        class="btn btn-dark col-1 offset-3 color-btn"
        >Edit
      </a>

      <!-- yehj bas show page hai isliye form sirf req bhehjne ke liye rakhe for delete.. Edit ke liye anchor tag req bhejega to edit.ejs per -->
      <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-dark offset-5">Delete</button>
      </form>
    </div>

    <div class="col-8 offset-3">
      <hr />
      <h4>Leave a review</h4>
      <form
        action="/listings/<%=listing.id %>/reviews"
        method="post"
        class="mb-3 needs-validation"
        novalidate
      >
        <div class="mb-3 mt-3">
          <label class="form-label" for="rating">Rating</label>
          <input
            type="range"
            min="1"
            max="5"
            id="rating"
            name="review[rating]"
            class="form-range"
          />
        </div>
        <div class="col-10 mb-3 mt-3">
          <label class="form-label" for="comment">Comments</label>
          <textarea
            name="review[comment]"
            id="comment"
            rows="5"
            class="form-control"
            required
          ></textarea>
          <!-- ==============To add what to add  in text area field if user dosent written anything ========================== -->
          <div class="invalid-feedback">Add description</div>
        </div>
        <button class="btn btn-outline-dark">SUmbit</button>
      </form>
      <hr />
     <p><b> All</b></p>
      
<div class="row">
      <% for(review of listing.reviews){ %>
      <div class="card col-5 mb-3 ms-3 ">
       <div class="card-body">
       <h5 class="card-tile">Jae do</h5>
       <p class="card-text"><%=review.comment%></p>
       <p class="card-text"><%=review.rating%> stars</p>
       </div>
       <form action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE" class="mb-3 mt-3" method="POST" >
        <button class="btn btn-sm btn-dark">Dekete</button>
       </form>
      </div>
        <%}%>
    </div>
  </div>
</div>
</body>
